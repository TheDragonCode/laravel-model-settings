{
    "name": "dragon-code/laravel-model-settings",
    "description": "Model Settings for your Laravel application",
    "license": "MIT",
    "keywords": [
        "The Dragon Code",
        "laravel",
        "laravel-model-settings"
    ],
    "authors": [
        {
            "name": "Andrey Helldar",
            "email": "helldar@dragon-code.pro"
        }
    ],
    "homepage": "https://github.com/dragon-code/laravel-model-settings",
    "require": {
        "php": "^8.2",
        "dragon-code/laravel-cache": "^4.0",
        "illuminate/contracts": "^10.0 || ^11.0 || ^12.0",
        "illuminate/collections": "^10.0 || ^11.0 || ^12.0",
        "illuminate/database": "^10.0 || ^11.0 || ^12.0",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "nunomaduro/collision": "^7.10.0 || ^8.1.1",
        "orchestra/testbench": "^8.22.0 || ^9.0.0 || ^10.0",
        "pestphp/pest": "^3.7.4",
        "pestphp/pest-plugin-laravel": "^3.1",
        "pestphp/pest-plugin-type-coverage": "^3.2.3",
        "roave/security-advisories": "dev-latest",
        "spatie/laravel-data": "^4.13"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "DragonCode\\LaravelModelSettings\\": "src/"
        },
        "files": [
            "helpers/settings.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "DragonCode\\LaravelModelSettings\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "DragonCode\\LaravelModelSettings\\ServiceProvider"
            ]
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "test": "vendor/bin/pest --parallel",
        "test:coverage": "vendor/bin/pest --coverage",
        "test:update": [
            "rm -rf tests/.pest/snapshots",
            "@test"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi"
    }
}
