{
    "name": "laravel-model-settings-docs",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "start": "docusaurus start",
        "build": "npm run check:i18n && docusaurus build",
        "serve": "docusaurus serve",
        "clear": "docusaurus clear",
        "typecheck": "tsc --noEmit",
        "docs:version": "docusaurus docs:version",
        "check:i18n": "node scripts/check-i18n.mjs",
        "translate": "npm run translate:en && npm run translate:ru && npm run translate:uk && npm run translate:be && npm run translate:fr && npm run translate:pt-BR && npm run translate:ko && npm run translate:zh-CN && npm run translate:de",
        "translate:en": "docusaurus write-translations --locale en",
        "translate:ru": "docusaurus write-translations --locale ru",
        "translate:uk": "docusaurus write-translations --locale uk",
        "translate:be": "docusaurus write-translations --locale be",
        "translate:fr": "docusaurus write-translations --locale fr",
        "translate:pt-BR": "docusaurus write-translations --locale pt-BR",
        "translate:ko": "docusaurus write-translations --locale ko",
        "translate:zh-CN": "docusaurus write-translations --locale zh-CN",
        "translate:de": "docusaurus write-translations --locale de"
    },
    "dependencies": {
        "@docusaurus/core": "3.10.2",
        "@docusaurus/faster": "3.10.2",
        "@docusaurus/preset-classic": "3.10.2",
        "@mdx-js/react": "^3.1.1",
        "clsx": "^2.1.1",
        "prism-react-renderer": "^2.4.1",
        "react": "^19.2.7",
        "react-dom": "^19.2.8"
    },
    "devDependencies": {
        "@docusaurus/module-type-aliases": "3.10.2",
        "@docusaurus/tsconfig": "3.10.2",
        "@docusaurus/types": "3.10.2",
        "@types/react": "^19.2.17",
        "typescript": "~6.0.3"
    },
    "overrides": {
        "serialize-javascript": "7.0.7",
        "uuid": "11.1.1"
    },
    "browserslist": {
        "production": [
            ">0.5%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 3 chrome version",
            "last 3 firefox version",
            "last 5 safari version"
        ]
    },
    "engines": {
        "node": ">=20.0"
    }
}
